[2.5, "o", "  Value: 0.08 ETH\r\n"]
[2.6, "o", "  Reason: \"Weekly contributor payroll — Alice\"\r\n"]
[2.9, "o", "  Decision: \u001b[32m\u001b[1mAPPROVE\u001b[0m\r\n"]
[3.0, "o", "  Reason: Whitelisted recipient, within limits\r\n"]
[3.1, "o", "\r\n"]
