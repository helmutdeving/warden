[1.2, "o", "\r\n"]
[1.5, "o", "\u001b[36m\u001b[1m=== Warden AI Treasury Agent — Demo ===\u001b[0m\r\n"]
[1.8, "o", "\r\n"]
[2.2, "o", "\u001b[36m▶ Routine payroll disbursement (whitelisted, 0.08 ETH)\u001b[0m\r\n"]
