[5.3, "o", "  Value: 0.01 ETH\r\n"]
[5.4, "o", "  Reason: \"Unknown recipient\"\r\n"]
[5.7, "o", "  Decision: \u001b[31m\u001b[1mREJECT\u001b[0m\r\n"]
